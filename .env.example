# ============================================================
# temporal-lens — environment variable reference
# Copy this file to .env and fill in your values.
# ============================================================

# --- Temporal ------------------------------------------------
# Address of your Temporal server (host:port).
# For Temporal Cloud use:  <namespace>.tmprl.cloud:7233
TEMPORAL_ADDRESS=localhost:7233

# Temporal namespace (default: "default")
TEMPORAL_NAMESPACE=default

# API key for Temporal Cloud (leave blank for self-hosted)
TEMPORAL_API_KEY=

# --- Langfuse ------------------------------------------------
# URL of your Langfuse instance (self-hosted or Langfuse Cloud)
LANGFUSE_HOST=http://localhost:3000

# Langfuse project credentials (found under Settings → API Keys)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- SSE / Polling -------------------------------------------
# How often the backend re-fetches and emits a graph snapshot (seconds)
POLL_INTERVAL_S=2
